# w-homepage-react PostgreSQL - Quadlet Configuration
# Generated by CodeB CLI v3.2.8
# Environment: staging
# Network: codeb-network (DNS-based container communication)

[Unit]
Description=w-homepage-react PostgreSQL staging Container
After=network-online.target

[Container]
Image=docker.io/library/postgres:15-alpine
ContainerName=w-homepage-react-staging-postgres
PublishPort=5433:5432
Network=codeb-network
Environment=POSTGRES_USER=postgres
Environment=POSTGRES_PASSWORD=postgres
Environment=POSTGRES_DB=w_homepage_react

Volume=w-homepage-react-staging-postgres-data:/var/lib/postgresql/data:Z
HealthCmd=pg_isready -U postgres
HealthInterval=30s
HealthTimeout=10s
HealthRetries=3
HealthStartPeriod=60s

[Service]
Restart=always
RestartSec=10s
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target default.target